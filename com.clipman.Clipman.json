{
    "id": "com.clipman.Clipman",
    "runtime": "org.gnome.Platform",
    "runtime-version": "46",
    "sdk": "org.gnome.Sdk",
    "command": "clipman",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--talk-name=org.gnome.Shell",
        "--talk-name=org.gnome.Shell.Extensions.clipman",
        "--filesystem=xdg-data/clipman:create"
    ],
    "modules": [
        {
            "name": "wl-clipboard",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/bugaevc/wl-clipboard/releases/download/v2.2.1/wl-clipboard-2.2.1.tar.gz",
                    "sha256": "6eb8081207fb5581d1d82c4bcd9587205571cb81e7832e52c5ba0a1d39538e05"
                }
            ]
        },
        {
            "name": "clipman",
            "buildsystem": "simple",
            "build-commands": [
                "install -d /app/share/clipman",
                "cp -r clipman/ /app/share/clipman/clipman/",
                "cp clipman.py /app/share/clipman/",
                "cp launcher.sh /app/share/clipman/",
                "chmod +x /app/share/clipman/launcher.sh",
                "install -Dm644 data/com.clipman.Clipman.desktop /app/share/applications/com.clipman.Clipman.desktop",
                "install -Dm644 data/com.clipman.Clipman.svg /app/share/icons/hicolor/scalable/apps/com.clipman.Clipman.svg",
                "install -Dm644 data/com.clipman.Clipman.metainfo.xml /app/share/metainfo/com.clipman.Clipman.metainfo.xml",
                "install -d /app/bin",
                "echo '#!/bin/sh' > /app/bin/clipman",
                "echo 'exec python3 /app/share/clipman/clipman.py \"$@\"' >> /app/bin/clipman",
                "chmod +x /app/bin/clipman"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
