#!/usr/bin/env bash
# pre-push hook: final defense before commits leave the machine.
#
# git invokes this with arguments (<remote-name> <remote-url>) and feeds
# <local-ref> <local-sha> <remote-ref> <remote-sha>\n lines on stdin for
# each ref being pushed.

# shellcheck source=.githooks/_lib.sh
. "$(dirname -- "$(readlink -f -- "$0" 2>/dev/null || printf '%s' "$0")")/_lib.sh"

remote_name="${1:-origin}"
remote_url="${2:-$(git remote get-url --push "$remote_name" 2>/dev/null || true)}"

failed=0

# ----- Push URL check ------------------------------------------------------

bad_urls=()
while IFS= read -r url; do
    [ -z "$url" ] && continue
    if ! contains_allowed_identity "$url"; then
        bad_urls+=("$url")
    fi
done < <(printf '%s\n' "$remote_url"; collect_push_urls)

if [ "${#bad_urls[@]}" -gt 0 ]; then
    hook_error "push URL points to an account outside the allowlist ($(allowed_list_for_message))"
    for u in "${bad_urls[@]}"; do hook_detail "$u"; done
    hook_detail "Reset: git remote set-url --push $remote_name git@github.com:MohammedEl-sayedAhmed/clipman.git"
    failed=1
fi

# ----- gh active account warning ------------------------------------------

active=$(gh_active_login)
if [ -n "$active" ] && ! contains_allowed_identity "$active"; then
    hook_warn "gh-CLI active account is '$active' (outside the allowlist)"
    hook_detail "ssh push is unaffected, but 'gh pr create / gh pr merge' would use this account."
    hook_detail "Switch: gh auth switch -u MohammedEl-sayedAhmed"
fi

# ----- Per-commit scan ----------------------------------------------------

zero=0000000000000000000000000000000000000000

scan_commit() {
    local sha="$1"
    local local_failed=0

    # Author + committer identity
    local ae ce an cn ident
    ae=$(git log -1 --format='%ae' "$sha")
    ce=$(git log -1 --format='%ce' "$sha")
    an=$(git log -1 --format='%an' "$sha")
    cn=$(git log -1 --format='%cn' "$sha")
    for ident in "$ae" "$ce" "$an" "$cn"; do
        if [ -n "$ident" ] && ! contains_allowed_identity "$ident"; then
            hook_error "commit $sha attributed to an account outside the allowlist"
            hook_detail "  $ident"
            local_failed=1
        fi
    done

    # Trailer-by-trailer identity check intentionally not done here:
    # Co-Authored-By / Signed-off-by / Reviewed-by routinely name external
    # contributors who are not on the personal allowlist, and rejecting
    # those would break normal PR-accepting flow. The Claude/Anthropic
    # footprint regex set in scan_footprints (below) already catches AI
    # attribution in any trailer line, which is the actual concern.

    # Footprint scan: message
    local message
    message=$(git log -1 --format='%B' "$sha")
    if ! printf '%s' "$message" | scan_footprints; then
        hook_error "commit $sha message contains a footprint"
        hook_detail "  $(git log -1 --format='%h %s' "$sha")"
        local_failed=1
    fi

    # Footprint scan: added content in non-allowlisted files (BYPASS-12)
    # We compare each commit against its parent; for root commits, against
    # an empty tree.
    local parents parent diffrange added_files
    parents=$(git log -1 --format='%P' "$sha")
    if [ -z "$parents" ]; then
        # Root commit
        diffrange="4b825dc642cb6eb9a060e54bf8d69288fbee4904..$sha"
    else
        parent=${parents%% *}  # first parent only (merge commits)
        diffrange="${parent}..${sha}"
    fi

    added_files=$(git diff --name-only --diff-filter=AM "$diffrange" 2>/dev/null || true)
    if [ -n "$added_files" ]; then
        local aggregated=""
        while IFS= read -r path; do
            [ -z "$path" ] && continue
            if is_path_allowlisted "$path"; then continue; fi
            local file_add
            file_add=$(git diff --no-color --diff-filter=AM "$diffrange" -- "$path" 2>/dev/null \
                       | awk '/^\+\+\+ /{next} /^\+/{print}')
            if [ -n "$file_add" ]; then
                aggregated="${aggregated}${file_add}"$'\n'
            fi
        done <<<"$added_files"

        if [ -n "$aggregated" ]; then
            if ! printf '%s' "$aggregated" | scan_footprints; then
                hook_error "commit $sha diff contains a footprint"
                hook_detail "  $(git log -1 --format='%h %s' "$sha")"
                local_failed=1
            fi
        fi
    fi

    return "$local_failed"
}

while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_sha" ] && continue
    [ "$local_sha" = "$zero" ] && continue  # branch deletion

    # Always scan only commits this push contributes to the remote:
    # ancestors reachable from local_sha but NOT from ANY ref on the
    # remote. This handles three cases uniformly —
    #   1. New branch off main: scans only the new commits, not main's
    #      history that's already on origin.
    #   2. Fast-forward update: scans only the new top-of-branch commits.
    #   3. Force-push after rebase / merge of main: scans only the
    #      rebased / merge commit, NOT the upstream commits pulled in
    #      from origin/main (which were already vetted when they merged).
    # The previous existing-branch path used $remote_sha..$local_sha,
    # which over-scanned in case (3): after rebasing onto an updated
    # main, every commit from main that wasn't reachable from the old
    # remote tip appeared in the range and tripped the identity check.
    commits=$(git rev-list "$local_sha" --not --remotes="$remote_name" 2>/dev/null)
    if [ -z "$commits" ] && [ "$remote_sha" = "$zero" ]; then
        # Fall back to a bounded local-only scan (last 200 commits) so a
        # brand-new remote with no refs to anchor against doesn't make
        # us iterate ALL of history.
        commits=$(git rev-list "$local_sha" --max-count=200)
    fi

    [ -z "$commits" ] && continue

    while IFS= read -r sha; do
        [ -z "$sha" ] && continue
        if ! scan_commit "$sha"; then
            failed=1
        fi
    done <<<"$commits"
done

if [ "$failed" -ne 0 ]; then
    hook_section "push aborted"
    hook_detail "To fix: amend or interactive-rebase the offending commit(s)."
    hook_detail "Bypass once (NOT recommended): git push --no-verify"
    exit 1
fi

hook_ok "push: identity + commits clean"
exit 0
